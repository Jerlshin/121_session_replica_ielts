DATABASE_URL=postgresql+asyncpg://ielts:ielts@localhost:5432/ielts_speaking
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60

CORS_ORIGINS=["http://localhost:3000"]

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=ielts
S3_SECRET_KEY=ielts-dev-secret
S3_BUCKET=ielts-media
S3_REGION=us-east-1

# Gemini Live API (Spec 01 §4.1, §3). Required for the WS gateway to
# connect to a real Gemini Live session — integration tests don't need
# this, they point GEMINI_LIVE_WS_URL at a local fixture-replay server
# instead (Spec 04 §3).
GEMINI_API_KEY=
# Config-driven per Spec 01 §4.1 — swap without a client deploy.
LIVE_MODEL_ID=models/gemini-2.0-flash-live-001
GEMINI_LIVE_WS_URL=wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1alpha.GenerativeService.BidiGenerateContent
