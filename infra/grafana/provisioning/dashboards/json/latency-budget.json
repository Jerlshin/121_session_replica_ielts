        },
        {
          "refId": "P95",
          "expr": "histogram_quantile(0.95, sum(rate(gateway_to_gemini_send_ms_milliseconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
